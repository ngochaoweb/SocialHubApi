
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    name      String
    username  String   @unique
    email     String   @unique
    passwordHash  String  
    createdAt DateTime @default(now()) 
    updatedAt DateTime @updatedAt 

    @@map("users")
}